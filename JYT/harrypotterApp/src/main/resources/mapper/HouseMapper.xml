<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.team7.harrypotter.mapper.HouseMapper">

    <select id="selectAllHouses" resultType="HouseDTO">
        SELECT *
        FROM house
        ORDER BY house_id
    </select>

    <select id="selectHouseById" parameterType="int" resultType="HouseDTO">
        SELECT *
        FROM house
        WHERE house_id = #{houseId}
    </select>

</mapper>